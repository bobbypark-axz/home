# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env*.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local tooling
/.claude/

# script progress files
lib/*.progress.json
lib/lh-complexes.json
lib/subway-stations.json
.cache/
.env*.local

# 큰 자산 — Vercel Blob 에 업로드, 매핑 JSON 으로 reference
# (.gitignore 인라인 comment 는 패턴의 일부로 해석되니 줄별로 분리)
public/lh-covers/
lib/notice-texts/
lib/notice-embeddings/vectors.bin
