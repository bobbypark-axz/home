# Naver Cloud Platform > Application > Client ID
# https://console.ncloud.com — Maps 서비스 등록 후 도메인 허용 필요
NEXT_PUBLIC_NAVER_MAPS_CLIENT_ID=

# Naver Cloud Maps Geocoding (REST) - 서버 사이드 (scripts/geocode-lh-naver.mjs)
# NCP Application 의 Client ID / Client Secret. (서버 IP 허용 필요)
NAVER_MAPS_CLIENT_ID=
NAVER_MAPS_CLIENT_SECRET=

# 공공데이터포털 마이홈포털 공공주택 모집공고 조회 서비스 (HWSPR02)
# https://www.data.go.kr/data/15110581/openapi.do
# Decoded 형태로 저장 (스크립트가 URL 인코딩 알아서 처리)
DATA_GO_KR_KEY=
